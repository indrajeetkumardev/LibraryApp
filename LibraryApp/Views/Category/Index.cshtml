@model List<LibraryApp.Models.Category>

@{
    ViewData["Title"] = "Categories";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0">
        <i class="bi bi-tags text-primary me-2"></i>Categories
    </h4>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-folder-plus me-1"></i>Add Category
    </a>
</div>

<div class="row g-3">
    @foreach (var cat in Model)
    {
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h5 class="fw-bold mb-1">
                                <i class="bi bi-folder-fill text-warning me-2"></i>
                                @cat.Name
                            </h5>
                            <p class="text-muted small mb-2">@cat.Description</p>
                            <span class="badge bg-primary-subtle text-primary">
                                @cat.Books.Count books
                            </span>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white border-top d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@cat.Id"
                       class="btn btn-sm btn-outline-warning flex-fill">
                        <i class="bi bi-pencil me-1"></i>Edit
                    </a>
                    <a asp-action="Delete" asp-route-id="@cat.Id"
                       class="btn btn-sm btn-outline-danger flex-fill"
                       onclick="return confirm('Delete karna chahte ho?')">
                        <i class="bi bi-trash me-1"></i>Delete
                    </a>
                </div>
            </div>
        </div>
    }
</div>