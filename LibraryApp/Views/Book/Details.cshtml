@model LibraryApp.Models.Book

@{
    ViewData["Title"] = Model.Title;
}

<!-- Breadcrumb -->
<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index"
               class="text-decoration-none">Dashboard</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-decoration-none">Books</a>
        </li>
        <li class="breadcrumb-item active">@Model.Title</li>
    </ol>
</nav>

<div class="row">

    <!-- Left: Book Info -->
    <div class="col-md-8">
        <div class="card">
            <div class="card-body p-4">

                <!-- Title + Badge -->
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <h3 class="fw-bold mb-1">@Model.Title</h3>
                        <p class="text-muted mb-0">by @Model.Author</p>
                    </div>
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success fs-6">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger fs-6">Issued</span>
                    }
                </div>

                <hr />

                <!-- Details Grid -->
                <div class="row g-3">
                    <div class="col-6">
                        <p class="text-muted small mb-1">Category</p>
                        <span class="badge bg-primary-subtle text-primary fs-6">
                            @Model.Category?.Name
                        </span>
                    </div>
                    <div class="col-6">
                        <p class="text-muted small mb-1">Price</p>
                        <h5 class="fw-bold text-success mb-0">₹@Model.Price</h5>
                    </div>
                    <div class="col-6">
                        <p class="text-muted small mb-1">Pages</p>
                        <p class="fw-semibold mb-0">@Model.Pages pages</p>
                    </div>
                    <div class="col-6">
                        <p class="text-muted small mb-1">Published</p>
                        <p class="fw-semibold mb-0">
                            @Model.PublishedDate.ToString("dd MMM yyyy")
                        </p>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.Description))
                {
                    <hr />
                    <p class="text-muted small mb-1">Description</p>
                    <p class="mb-0">@Model.Description</p>
                }

                <hr />

                <!-- Action Buttons -->
                <div class="d-flex gap-2">
                    <a asp-action="Edit" asp-route-id="@Model.Id"
                       class="btn btn-warning">
                        <i class="bi bi-pencil me-1"></i>Edit Book
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back to List
                    </a>
                </div>

            </div>
        </div>
    </div>

    <!-- Right: Cover Image -->
    <div class="col-md-4">
        <div class="card">
            <div class="card-body text-center p-4">
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <img src="@Model.CoverImageUrl"
                         alt="@Model.Title"
                         class="img-fluid rounded shadow-sm"
                         style="max-height:300px" />
                }
                else
                {
                    <div class="bg-light rounded d-flex align-items-center
                                    justify-content-center"
                         style="height:250px">
                        <div class="text-center text-muted">
                            <i class="bi bi-book" style="font-size:4rem"></i>
                            <p class="mt-2">No Cover Image</p>
                        </div>
                    </div>
                }
                <p class="text-muted small mt-3 mb-0">@Model.Title</p>
            </div>
        </div>
    </div>

</div>