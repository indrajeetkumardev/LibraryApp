@model LibraryApp.Models.Book

@{
    ViewData["Title"] = "Add Book";
}

<nav aria-label="breadcrumb" class="mb-4">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-controller="Home" asp-action="Index"
               class="text-decoration-none">Dashboard</a>
        </li>
        <li class="breadcrumb-item">
            <a asp-action="Index" class="text-decoration-none">Books</a>
        </li>
        <li class="breadcrumb-item active">Add Book</li>
    </ol>
</nav>

<div class="row justify-content-center">
    <div class="col-md-8">
        <div class="card">
            <div class="card-header bg-primary text-white py-3">
                <h5 class="mb-0">
                    <i class="bi bi-plus-circle me-2"></i>Add New Book
                </h5>
            </div>
            <div class="card-body p-4">

                <div asp-validation-summary="ModelOnly"
                     class="alert alert-danger small py-2"></div>

                <form asp-action="Create" method="post">

                    <!-- Row 1: Title + Author -->
                    <div class="row">
                        <div class="col-md-7 mb-3">
                            <label asp-for="Title" class="form-label fw-semibold"></label>
                            <input asp-for="Title" class="form-control"
                                   placeholder="Book ka title" />
                            <span asp-validation-for="Title"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-5 mb-3">
                            <label asp-for="Author" class="form-label fw-semibold"></label>
                            <input asp-for="Author" class="form-control"
                                   placeholder="Author ka naam" />
                            <span asp-validation-for="Author"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Row 2: Category + Price + Pages -->
                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label asp-for="CategoryId" class="form-label fw-semibold">
                                Category
                            </label>
                            <select asp-for="CategoryId"
                                    asp-items="ViewBag.Categories"
                                    class="form-select">
                                <option value="">-- Select Category --</option>
                            </select>
                            <span asp-validation-for="CategoryId"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-4 mb-3">
                            <label asp-for="Price" class="form-label fw-semibold"></label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                <input asp-for="Price" class="form-control"
                                       placeholder="0.00" />
                            </div>
                            <span asp-validation-for="Price"
                                  class="text-danger small"></span>
                        </div>
                        <div class="col-md-3 mb-3">
                            <label asp-for="Pages" class="form-label fw-semibold"></label>
                            <input asp-for="Pages" class="form-control"
                                   placeholder="Pages" />
                            <span asp-validation-for="Pages"
                                  class="text-danger small"></span>
                        </div>
                    </div>

                    <!-- Row 3: Date + Image URL -->
                    <div class="row">
                        <div class="col-md-5 mb-3">
                            <label asp-for="PublishedDate"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="PublishedDate"
                                   type="date" class="form-control" />
                        </div>
                        <div class="col-md-7 mb-3">
                            <label asp-for="CoverImageUrl"
                                   class="form-label fw-semibold"></label>
                            <input asp-for="CoverImageUrl" class="form-control"
                                   placeholder="https://..." />
                        </div>
                    </div>

                    <!-- Description -->
                    <div class="mb-3">
                        <label asp-for="Description" class="form-label fw-semibold"></label>
                        <textarea asp-for="Description" class="form-control"
                                  rows="3" placeholder="Book ke baare mein..."></textarea>
                    </div>

                    <!-- Available Switch -->
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="IsAvailable"
                                   class="form-check-input" role="switch" />
                            <label asp-for="IsAvailable"
                                   class="form-check-label fw-semibold">
                                Available for Issue
                            </label>
                        </div>
                    </div>

                    <hr />

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-fill">
                            <i class="bi bi-check-circle me-1"></i>Save Book
                        </button>
                        <a asp-action="Index" class="btn btn-outline-secondary flex-fill">
                            <i class="bi bi-arrow-left me-1"></i>Cancel
                        </a>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}